# Multi-stage Dockerfile for Cloud Run deployment
# Build stage: Compile dependencies
FROM python:3.11-slim as builder

WORKDIR /build

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements (use minimal version with verified packages)
COPY backend/requirements-minimal.txt .

# Build wheels - install to /usr/local (not --user)
RUN pip install --no-cache-dir --upgrade pip setuptools wheel && \
    pip install --no-cache-dir -r requirements-minimal.txt

# Runtime stage: Minimal production image
FROM python:3.11-slim

WORKDIR /app

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app/backend:$PYTHONPATH \
    PATH=/usr/local/bin:$PATH \
    PORT=8080

# Install runtime dependencies only
RUN apt-get update && apt-get install -y --no-install-recommends \
    postgresql-client \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Copy Python packages from builder
COPY --from=builder /usr/local /usr/local

# Copy application code
COPY backend ./backend/

# Create frontend directory (dist artifacts optional)
RUN mkdir -p ./frontend/dist

# Create necessary directories
RUN mkdir -p /app/media /app/static /app/logs

# Set working directory to backend (where manage.py and wsgi.py are)
WORKDIR /app/backend

# Set permissions - run as root (container is sandboxed)
RUN chown -R root:root /app

# Run as root (safe in containerized environment)
USER root

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:${PORT}/api/health/ || exit 1

# Expose port
EXPOSE ${PORT}

# Run gunicorn
CMD ["gunicorn", \
     "--workers=4", \
     "--worker-class=sync", \
     "--bind=0.0.0.0:8080", \
     "--timeout=120", \
     "--access-logfile=-", \
     "--error-logfile=-", \
     "--log-level=info", \
     "pavilion_gemini.wsgi:application"]
