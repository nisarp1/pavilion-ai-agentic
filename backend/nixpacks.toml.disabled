[phases.setup]
nixPkgs = [
    "python311",
    "postgresql",
    "gcc",
    "libffi",
    "openssl",
    "zlib",
    "libjpeg",
    "pkg-config"
]

[variables]
NIXPACKS_PYTHON_VERSION = '3.11'

[phases.build]
cmds = [
    "pip install --upgrade pip",
    "pip install -r requirements.txt",
    "python manage.py collectstatic --noinput",
    "python manage.py migrate"
]

[start]
cmd = "gunicorn pavilion_gemini.wsgi --bind 0.0.0.0:$PORT --timeout 120"
