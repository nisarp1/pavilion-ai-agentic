    {
      "id": "captioned_video",
      "composition_id": "CaptionedVideo",
      "name": "TikTok Captioned Video",
      "category": "custom",
      "status": "active",
      "source": "custom",
      "description": "Full-screen video playback with TikTok-style auto-captions. Renders a source video (mp4/webm/mkv/mov) and overlays word-by-word highlighted captions loaded from a Whisper-generated JSON file. Active word highlights in bright green (configurable). Caption font is TheBoldFont in uppercase. Duration is calculated dynamically from the video file itself. Ideal for voiceover videos, social clips, reels with auto-subtitles, or any video that needs accessibility captions. Requires a pre-generated Whisper caption JSON file at the same path as the video (e.g., video.mp4 → video.json).",
      "duration": {
        "default_seconds": 30,
        "default_frames": 900,
        "min_seconds": 5,
        "max_seconds": 300
      },
      "props": {
        "required": [
          {
            "key": "src",
            "type": "string",
            "description": "URL or static filename of the source video (mp4/webm/mkv/mov). A matching .json caption file must exist at the same path.",
            "example": "https://storage.googleapis.com/bucket/reel_01.mp4"
          }
        ],
        "optional": [
          {
            "key": "highlightColor",
            "type": "string",
            "default": "#39E508",
            "description": "Active word highlight color (any CSS color)",
            "example": "#FFD700"
          }
        ]
      },
      "assets": [
        {
          "slot": "src",
          "type": "video",
          "description": "Source video file. The pipeline also needs a Whisper-generated caption JSON at the same path with .json extension.",
          "required": true,
          "aspect_ratio": "9:16",
          "search_hint": "source video for captioning"
        }
      ],
      "suitable_for": [
        "voiceover_video",
        "social_clip",
        "reel_with_captions",
        "interview_clip",
