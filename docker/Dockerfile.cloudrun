# Multi-stage Dockerfile for Cloud Run deployment
# Build stage 1: Build frontend
FROM node:18-slim as frontend-builder

WORKDIR /frontend
COPY frontend/package*.json ./
RUN npm ci
COPY frontend .
ARG VITE_API_BASE_URL=/api
ARG VITE_GOOGLE_CLIENT_ID=placeholder
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
ENV VITE_GOOGLE_CLIENT_ID=${VITE_GOOGLE_CLIENT_ID}
RUN npm run build

# Build stage 2: Compile Python dependencies
FROM python:3.11-slim as builder

WORKDIR /build

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements
COPY backend/requirements.txt .

# Build wheels - install to /usr/local (not --user)
RUN pip install --no-cache-dir --upgrade pip setuptools wheel && \
    pip install --no-cache-dir -r requirements.txt

# Runtime stage: Minimal production image
FROM python:3.11-slim

WORKDIR /app

# Set environment variables
# PYTHONPATH ensures we can import packages installed in /usr/local (like cloud-sql-python-connector)
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app/backend:/usr/local/lib/python3.11/site-packages \
    PATH=/usr/local/bin:$PATH \
    PORT=8080

# Install runtime dependencies only
# Including libssl3 for cryptography (required by cloud-sql-python-connector)
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    postgresql-client \
    curl \
    ca-certificates \
    libssl3 \
    && rm -rf /var/lib/apt/lists/*

# Copy Python packages from builder
COPY --from=builder /usr/local /usr/local

# Verify basic packages are installed (cloud-sql-python-connector will fall back gracefully if missing)
RUN python3 -c "import celery; import redis; print('✓ Celery and Redis imported successfully')"

# Copy frontend build artifacts
COPY --from=frontend-builder /frontend/dist ./frontend/dist

# Copy application code
COPY backend ./backend/
COPY docker/entrypoint.sh ./docker/entrypoint.sh

# Create necessary directories
RUN mkdir -p /app/media /app/static /app/logs

# Copy frontend static files to Django static directory for serving
RUN mkdir -p /app/backend/staticfiles && \
    cp -r /app/frontend/dist/* /app/backend/staticfiles/ || true

# Make entrypoint executable
RUN chmod +x ./docker/entrypoint.sh

# Set working directory to backend (where manage.py and wsgi.py are)
WORKDIR /app/backend

# Set permissions - run as root (container is sandboxed)
RUN chown -R root:root /app

# Run as root (safe in containerized environment)
USER root

# Health check (start-period=120s to allow time for migrations and database connection)
HEALTHCHECK --interval=10s --timeout=5s --start-period=120s --retries=5 \
    CMD curl -f http://localhost:${PORT}/health/ || exit 1

# Expose port
EXPOSE ${PORT}

# Run entrypoint script
ENTRYPOINT ["/app/docker/entrypoint.sh"]
