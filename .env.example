# ============================================================================
# Pavilion-AI Agentic CMS - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your configuration
# DO NOT commit .env to version control
# ============================================================================

# ============================================================================
# Google Cloud Configuration
# ============================================================================
GOOGLE_PROJECT_ID=pavilion-ai-agentic
GOOGLE_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=.gcp-secrets/service-account-key.json

# ============================================================================
# Database Configuration
# ============================================================================
# Local development (using Cloud SQL Proxy)
DATABASE_URL=postgresql://pavilion_user:your_password_here@127.0.0.1:5432/pavilion_agentic

# Cloud SQL Connection String (for Cloud Run)
DATABASE_SOCKET_PATH=/cloudsql/YOUR_PROJECT_ID:us-central1:pavilion-db-dev

# Database Backup (optional)
DATABASE_BACKUP_BUCKET=pavilion-ai-backups-dev

# ============================================================================
# Cloud Storage Configuration
# ============================================================================
GCS_BUCKET_MEDIA=pavilion-ai-media-dev
GCS_BUCKET_STATIC=pavilion-ai-static-dev
GCS_BUCKET_LOGS=pavilion-ai-logs-dev

# Storage settings
STATIC_URL=/static/
MEDIA_URL=/media/
STATIC_ROOT=./static/
MEDIA_ROOT=./media/

# ============================================================================
# Django Settings
# ============================================================================
SECRET_KEY=change-me-in-production-use-strong-random-key-of-at-least-50-chars
DEBUG=False
ENVIRONMENT=development

# Allowed hosts for deployment
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,.run.app

# Django settings module
DJANGO_SETTINGS_MODULE=pavilion_gemini.settings

# ============================================================================
# Vertex AI & LLM Configuration
# ============================================================================
VERTEX_AI_MODEL=gemini-2.0-flash-exp
VERTEX_AI_EMBEDDING_MODEL=text-embedding-004
VERTEX_AI_EMBEDDING_DIMENSIONS=256

# LangChain configuration
LANGCHAIN_VERBOSE=false
LANGCHAIN_LLM_BACKEND=vertex_ai

# Vector Search configuration
VECTOR_SEARCH_INDEX_ID=pavilion-article-embeddings
VECTOR_SEARCH_ENDPOINT_ID=pavilion-search-endpoint
VECTOR_SEARCH_DEPLOYED_INDEX_ID=pavilion_embeddings_v1

# ============================================================================
# API Keys (if using external services - Phase 5)
# ============================================================================
# Optional: Only if maintaining compatibility with external services

# OpenAI (for fallback or migration period)
# OPENAI_API_KEY=sk-...

# ElevenLabs (for audio, if not migrating to Google TTS)
# ELEVENLABS_API_KEY=...
# ELEVENLABS_MALAYALAM_VOICE_ID=George

# D-ID (for video, if not migrating to Vertex AI)
# D_ID_API_KEY=...

# ============================================================================
# Google Cloud Text-to-Speech Configuration
# ============================================================================
GOOGLE_TTS_LANGUAGE_CODE=ml-IN
GOOGLE_TTS_VOICE_GENDER=NEUTRAL
GOOGLE_TTS_AUDIO_ENCODING=MP3

# ============================================================================
# Celery & Background Tasks Configuration
# ============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json

# Cloud Tasks Configuration (for Cloud Run)
CLOUD_TASKS_QUEUE=pavilion-tasks-dev
CLOUD_TASKS_LOCATION=us-central1

# ============================================================================
# Email Configuration (for notifications)
# ============================================================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# Admin email
ADMIN_EMAIL=admin@example.com
DEFAULT_FROM_EMAIL=noreply@pavilion.local

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
CLOUD_LOGGING_ENABLED=true
CLOUD_LOGGING_PROJECT_ID=pavilion-ai-agentic

# ============================================================================
# Security Configuration
# ============================================================================
# CORS settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000

# CSRF settings
CSRF_TRUSTED_ORIGINS=localhost,127.0.0.1

# Session security
SESSION_COOKIE_SECURE=false  # Set to true in production
CSRF_COOKIE_SECURE=false      # Set to true in production
SESSION_COOKIE_HTTPONLY=true
CSRF_COOKIE_HTTPONLY=true

# ============================================================================
# Analytics Configuration (Phase 4)
# ============================================================================
GA4_PROPERTY_ID=your-ga4-property-id
GA4_CREDENTIALS_PATH=.gcp-secrets/ga4-credentials.json

# ============================================================================
# Agent Configuration
# ============================================================================
# Agent request timeout (seconds)
AGENT_TIMEOUT=300

# Maximum retries for agent tasks
AGENT_MAX_RETRIES=3

# Enable agent logging
AGENT_DEBUG_LOGGING=true

# ============================================================================
# Feature Flags
# ============================================================================
FEATURE_EMBEDDINGS_ENABLED=true
FEATURE_AGENTS_ENABLED=true
FEATURE_SEMANTIC_SEARCH_ENABLED=true
FEATURE_VIDEO_GENERATION_ENABLED=false  # Phase 5
FEATURE_IMAGE_GENERATION_ENABLED=false  # Phase 5
FEATURE_HITL_ENABLED=false              # Phase 3 (disabled by default)

# ============================================================================
# Development Settings
# ============================================================================
# Only for local development
DEVELOPMENT_MODE=true
MOCK_VERTEX_AI=false  # Set to true to mock Vertex AI responses in development
MOCK_STORAGE=false    # Set to true to use local filesystem instead of GCS

# ============================================================================
# Monitoring & Performance
# ============================================================================
ENABLE_PROFILING=false
ENABLE_QUERY_LOGGING=false
ENABLE_CACHE_STATS=true

# Cache configuration
CACHES_BACKEND=django.core.cache.backends.redis.RedisCache
CACHE_TIMEOUT=3600  # 1 hour

# ============================================================================
# API Configuration
# ============================================================================
API_RATE_LIMIT_ENABLED=false  # Set to true in production
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_PERIOD=3600

# API versioning
API_VERSION=v1

# ============================================================================
# Backup & Recovery Configuration
# ============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM UTC
BACKUP_RETENTION_DAYS=30

# ============================================================================
# Notes
# ============================================================================
# 1. Database URL format:
#    postgresql://user:password@host:port/database
#    For Cloud SQL Proxy: postgresql://user:password@127.0.0.1:5432/database
#
# 2. For production, use strong SECRET_KEY (50+ random characters)
#    Generate with: python -c 'import secrets; print(secrets.token_urlsafe(50))'
#
# 3. Sensitive data should be stored in Google Cloud Secret Manager
#    In production, retrieve secrets via secretmanager API
#
# 4. Cloud SQL Proxy command:
#    cloud_sql_proxy -instances=PROJECT_ID:us-central1:pavilion-db-dev=tcp:5432
#
# 5. Verify all paths exist before starting application:
#    - .gcp-secrets/service-account-key.json (after GCP setup)
#    - media/, static/ directories
#
# 6. Never commit passwords, API keys, or .env files to version control
#    Use .gitignore to exclude: .env, .env.*, .gcp-secrets/
