# Multi-stage Dockerfile for Cloud Run deployment
# Build stage: Compile dependencies
FROM python:3.11-slim as builder

WORKDIR /build

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements
COPY backend/requirements.txt .

# Build wheels - install to /usr/local (not --user)
RUN pip install --no-cache-dir --upgrade pip setuptools wheel && \
    pip install --no-cache-dir -r requirements.txt

# Runtime stage: Minimal production image
FROM python:3.11-slim

WORKDIR /app

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app/backend:/usr/local/lib/python3.11/site-packages:$PYTHONPATH \
    PATH=/usr/local/bin:$PATH \
    PORT=8080

# Install runtime dependencies only
# Including libssl3 for cryptography (required by cloud-sql-python-connector)
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    postgresql-client \
    curl \
    ca-certificates \
    libssl3 \
    && rm -rf /var/lib/apt/lists/*

# Copy Python packages from builder
COPY --from=builder /usr/local /usr/local

# Verify critical packages are installed
RUN python3 -c "import celery; import redis; from cloud_sql_python_connector import Connector; print('✓ Celery, Redis, and cloud-sql-python-connector imported successfully')"

# Copy application code
COPY backend ./backend/
COPY docker/entrypoint.sh ./docker/entrypoint.sh

# Create frontend directory (dist artifacts optional)
RUN mkdir -p ./frontend/dist

# Create necessary directories
RUN mkdir -p /app/media /app/static /app/logs

# Make entrypoint executable
RUN chmod +x ./docker/entrypoint.sh

# Set working directory to backend (where manage.py and wsgi.py are)
WORKDIR /app/backend

# Set permissions - run as root (container is sandboxed)
RUN chown -R root:root /app

# Run as root (safe in containerized environment)
USER root

# Health check (start-period=120s to allow time for migrations and database connection)
HEALTHCHECK --interval=10s --timeout=5s --start-period=120s --retries=5 \
    CMD curl -f http://localhost:${PORT}/health/ || exit 1

# Expose port
EXPOSE ${PORT}

# Run entrypoint script
ENTRYPOINT ["/app/docker/entrypoint.sh"]
